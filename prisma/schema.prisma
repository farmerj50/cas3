generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String      @id @default(cuid())
  email                String      @unique
  password             String
  tier                 String      @default("free")   // "free" | "premium"
  state                String      @default("GA")     // user's selected state code
  stripeCustomerId     String?     @unique
  stripeSubscriptionId String?     @unique
  stripePriceId        String?
  subscriptionStatus   String?
  premiumExpiresAt     DateTime?   // set for day/week pass holders
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  picks                Pick[]
  auditLogs            AuditLog[]
  pushTokens           PushToken[]
}

model PushToken {
  id        String   @id @default(cuid())
  token     String   @unique
  platform  String   @default("unknown")  // "ios" | "android"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Pick {
  id             String    @id @default(cuid())
  numbers        String
  score          Float
  algorithm      String
  playType       String    @default("box")   // "straight" | "box" | "combo"
  intendedDate   String?                      // ISO date the pick is for
  intendedPeriod String?                      // "midday" | "evening" | "night"
  createdAt      DateTime  @default(now())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isHit          Boolean?
  drawResult     String?
  checkedAt      DateTime?
}

model Draw {
  id        String   @id @default(cuid())
  numbers   String
  drawDate  String
  period    String
  state     String   @default("GA")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  event     String
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  meta      String?
}
